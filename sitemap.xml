---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>{{ site.url }}{{ '/' | relative_url }}</loc></url>
{% for page in site.pages %}{% if page.url != '/404.html' and page.url != '/feed.xml' and page.url != '/sitemap.xml' and page.url != '/robots.txt' %}
  <url><loc>{{ site.url }}{{ page.url | relative_url | xml_escape }}</loc></url>
{% endif %}{% endfor %}{% for post in site.posts %}
  <url><loc>{{ site.url }}{{ post.url | relative_url | xml_escape }}</loc><lastmod>{{ post.date | date_to_xmlschema }}</lastmod></url>
{% endfor %}</urlset>
